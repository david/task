{
  "name": "task",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "bun run lint:eslint && bun run lint:deps",
    "lint:eslint": "eslint --max-warnings 0 src",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs src",
    "test": "bun test ./src ./task.test.ts ./commands.test.ts",
    "build:legacy": "bun build ./task.ts --compile --outfile ./dist/task-legacy"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
